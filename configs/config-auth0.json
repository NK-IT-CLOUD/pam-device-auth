{
    "issuer_url": "https://your-tenant.auth0.com",
    "client_id": "your-client-id",
    "required_role": "ssh-access",
    "sudo_role": "ssh-admin",
    "role_claim": "https://your-app.example.com/roles",
    "auth_timeout": 180,
    "create_user": true,
    "user_groups": ["users"],
    "admin_groups": ["sudo", "users"],
    "force_password_change": true
}
