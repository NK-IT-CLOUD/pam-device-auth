#!/bin/bash
set -e

SHARE_DIR="/usr/share/keycloak-ssh-auth"
CONFIG_DIR="/etc/keycloak-ssh-auth"
CONFIG_FILE="${CONFIG_DIR}/keycloak-pam.json"
LOG_FILE="/var/log/keycloak-ssh-auth.log"

check_os_compatibility() {
    if [ -f /etc/os-release ]; then
        . /etc/os-release
        case "$ID" in
            ubuntu)
                if [ "${VERSION_ID%%.*}" -lt 24 ]; then
                    echo "WARNING: Ubuntu 24.04+ recommended (found $VERSION_ID)"
                fi
                ;;
            debian)
                if [ "${VERSION_ID%%.*}" -lt 12 ]; then
                    echo "WARNING: Debian 12+ recommended (found $VERSION_ID)"
                fi
                ;;
        esac
    fi
}

setup_logrotate() {
    cat > /etc/logrotate.d/keycloak-ssh-auth << 'LOGROTATE'
/var/log/keycloak-ssh-auth.log {
    weekly
    rotate 4
    compress
    delaycompress
    missingok
    notifempty
    create 0644 root root
}
LOGROTATE
}

case "$1" in
    configure)
        check_os_compatibility
        setup_logrotate

        # Create directories
        mkdir -p /etc/ssh/sshd_config.d
        mkdir -p "$CONFIG_DIR"

        # Install SSH config
        cp "${SHARE_DIR}/config/10-keycloak-auth.conf" /etc/ssh/sshd_config.d/

        # Install PAM config (backup original first)
        if [ -f /etc/pam.d/sshd ] && [ ! -f /etc/pam.d/sshd.original ]; then
            cp /etc/pam.d/sshd /etc/pam.d/sshd.original
        fi
        cp "${SHARE_DIR}/config/pam-sshd-keycloak" /etc/pam.d/sshd

        # Install config (preserve existing custom config)
        if [ ! -f "$CONFIG_FILE" ]; then
            cp "${SHARE_DIR}/config/keycloak-pam.json" "$CONFIG_FILE"
        fi

        # Set permissions
        chmod 755 /usr/local/bin/keycloak-auth
        chmod 755 /usr/lib/security/pam_keycloak.so
        chmod 600 "$CONFIG_FILE"

        # Create log file
        touch "$LOG_FILE"
        chmod 644 "$LOG_FILE"

        # Restart SSH
        if command -v systemctl >/dev/null 2>&1; then
            systemctl restart ssh.service 2>/dev/null || systemctl restart sshd.service 2>/dev/null || true
        fi

        echo "keycloak-ssh-auth 0.5.0 installed successfully."
        ;;
esac

exit 0
